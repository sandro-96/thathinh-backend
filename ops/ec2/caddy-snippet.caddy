# Thêm block này vào Caddyfile trên EC2 (cùng file với api.sotuci.vn).
# Sau khi sửa: sudo systemctl reload caddy

api.thathinh.vn {
    encode gzip zstd

    reverse_proxy 127.0.0.1:8081 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    log {
        output file /var/log/caddy/thathinh-api.log {
            roll_size 10mib
            roll_keep 5
        }
        format json
    }
}
