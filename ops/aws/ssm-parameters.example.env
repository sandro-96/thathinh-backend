# SSM Parameter Store — prefix /thathinh/prod/
# Tạo từng param (SecureString cho secrets):
#
# aws ssm put-parameter --name /thathinh/prod/MONGODB_URI --value "mongodb+srv://..." --type SecureString --overwrite
# aws ssm put-parameter --name /thathinh/prod/JWT_SECRET --value "..." --type SecureString --overwrite
#
# Tham số bắt buộc:

SPRING_PROFILES_ACTIVE=prod
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/thathinhdb?retryWrites=true&w=majority
MONGODB_DATABASE=thathinhdb
JWT_SECRET=change-me-min-32-chars-random

FRONTEND_URL=https://thathinh.vn
CORS_ORIGIN_0=https://thathinh.vn
CORS_ORIGIN_1=https://www.thathinh.vn
CORS_ORIGIN_2=

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

AWS_S3_BUCKET=thathinh-assets
AWS_S3_REGION=ap-southeast-1
AWS_S3_PUBLIC_URL_BASE=
AWS_S3_REQUIRED=true
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

EMAIL_VERIFICATION_REQUIRED=false
REDIS_ENABLED=false
MAIL_HEALTH_ENABLED=false

# Tuỳ chọn
ADMIN_SEED_ENABLED=false
ADMIN_EMAIL=admin@thathinh.vn
ADMIN_PASSWORD=
